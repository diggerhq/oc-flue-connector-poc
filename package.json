{
  "name": "@opencomputer/flue",
  "version": "0.0.1",
  "description": "OpenComputer sandbox connector for the Flue agent framework",
  "type": "module",
  "main": "dist/opencomputer.js",
  "types": "dist/opencomputer.d.ts",
  "exports": {
    ".": {
      "types": "./dist/opencomputer.d.ts",
      "import": "./dist/opencomputer.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "check:types": "tsc --noEmit"
  },
  "keywords": [
    "flue",
    "opencomputer",
    "sandbox",
    "agent",
    "ai",
    "connector"
  ],
  "author": "Digger",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/diggerhq/oc-flue-connector-poc.git"
  },
  "bugs": {
    "url": "https://github.com/diggerhq/oc-flue-connector-poc/issues"
  },
  "homepage": "https://github.com/diggerhq/oc-flue-connector-poc#readme",
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@flue/sdk": "*",
    "@opencomputer/sdk": "*"
  },
  "devDependencies": {
    "@flue/sdk": "*",
    "@opencomputer/sdk": "*",
    "typescript": "^5.4.0"
  }
}
